<launch>
  <param name="use_sim_time" value="true"/>

  <include file="$(find wpr_simulation)/launch/wpb_stage_slam.launch"/>

  <!-- Hector SLAM（彻底关闭 map_odom 发布，从根源消灭报错） -->
  <node pkg="hector_mapping" type="hector_mapping" name="hector_mapping" output="screen">
    <param name="base_frame" value="base_link"/>
    <param name="odom_frame" value="odom"/>
    <param name="map_frame" value="map"/>
    <param name="scan_topic" value="scan"/>

    <!-- 🔥 核心：彻底关闭 Hector 发布 map->odom -->
    <param name="pub_map_odom_transform" value="false"/>

    <!-- 其他稳定参数 -->
    <param name="use_tf_scans" value="false"/>
    <param name="use_sim_time" value="true"/>

    <param name="map_update_distance_thresh" value="0.1"/>
    <param name="map_update_angle_thresh" value="0.1"/>
    <param name="map_pub_period" value="0.1"/>
    <param name="map_update_interval" value="0.1"/>
  </node>

  <!-- 🔥 关键：用静态TF补全 map <-> odom，彻底不报错 -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="map_to_odom"
    args="0 0 0  0 0 0  map odom  100" />

  <node pkg="rviz" type="rviz" name="rviz" args="-d $(find slam_pkg)/rviz/slam.rviz" respawn="true"/>
  <node pkg="rqt_robot_steering" type="rqt_robot_steering" name="rqt_robot_steering"/>

</launch>
